# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
# Python distribution / packaging — anchored to repo root so they don't
# eat src/lib/ etc. (Standard Python .gitignore templates use bare
# `lib/`, which is too greedy in polyglot repos.)
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Environments
.venv/
venv/
ENV/
env/
.env
.env.*
!.env.example

# uv
# (uv.lock is committed; .venv is not)

# Tests / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Linters / type checkers
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/

# Jupyter / notebooks
.ipynb_checkpoints/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Blender
*.blend1
*.blend2
*.blend@
*.blend.bak

# Project-specific
# Local demo assets users download per docs/demo_setup.md
~/.modpilot_assets/
ModPilot/.modpilot_state/
# Persisted user config (~/.modpilot/config.json holds LLM API keys in plain text).
# Belt-and-suspenders: the path lives in the user's home, so git wouldn't see it
# unless someone copies it into the repo. Keep this line so that mistake is caught.
.modpilot/
~/.modpilot/

# Logs
*.log
logs/
docs/conversation-2026-05-11.md

# Secrets — make sure no API keys ever get tracked
*.key
*.pem
secrets/

# Claude Code local project config (user-specific)
.claude/

# External Blender addons — installed separately, see README.md Prerequisites
Modding-Toolkit/
blender-mcp/
ModPilot/app/phases/REE-ModPilot.code-workspace

# Frontend (React + Vite)
ModPilot/frontend/node_modules/
ModPilot/frontend/dist/
ModPilot/frontend/.vite/
# TypeScript incremental-build caches — regenerated on every `tsc -b`.
*.tsbuildinfo
# Vite build output served by FastAPI at /. Rebuilt by `pnpm build` —
# keep it out of source control so commits don't carry hashed bundles.
ModPilot/app/static_built/

# Tauri desktop shell (Rust)
ModPilot/frontend/src-tauri/target/
ModPilot/frontend/src-tauri/gen/
ModPilot/frontend/src-tauri/Cargo.lock
# Staged backend sidecar copy — produced by `pyinstaller modpilot_backend.spec`
# then `cp -r ModPilot/dist/modpilot-backend src-tauri/binaries/backend`.
# Rebuilt on every backend exe rebuild; too large to track.
ModPilot/frontend/src-tauri/binaries/

# Pyinstaller scratch output
ModPilot/build/
ModPilot/dist/

# Playwright walkthrough recordings — local-only, regenerated by
# scripts/record_*_walkthrough.py. Webms are too large for git history.
ModPilot/artifacts/

# study folder for personal learning
_study/