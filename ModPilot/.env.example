# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real keys.

# ── LLM provider ──────────────────────────────────────────────
# Three provider modes:
#   "openai_compatible" — OpenAI SDK with custom base_url (DeepSeek OpenAI API, Qwen, etc.)
#   "anthropic"         — Anthropic SDK; also supports DeepSeek's Anthropic-compatible endpoint
#   "ollama"            — Ollama Cloud (POST /api/chat) or a local Ollama daemon
LLM_PROVIDER=openai_compatible

# API key for the chosen provider
LLM_API_KEY=your-api-key-here

# Model string — provider-specific
# DeepSeek V4 (OpenAI-compat):    deepseek-chat       + LLM_BASE_URL=https://api.deepseek.com/v1
# DeepSeek V4 (Anthropic-compat): deepseek-chat       + LLM_BASE_URL=https://api.deepseek.com/anthropic
# Real Claude:                    claude-sonnet-4-6   + LLM_BASE_URL= (leave empty)
# Ollama Cloud V4:                deepseek-v4-flash   + LLM_BASE_URL= (default: https://ollama.com)
LLM_MODEL=deepseek-chat

# Base URL — interpretation depends on LLM_PROVIDER:
#   openai_compatible : always required (e.g. https://api.deepseek.com/v1)
#   anthropic         : optional — leave empty for real Anthropic; set to
#                       https://api.deepseek.com/anthropic for DeepSeek via Anthropic protocol
#   ollama            : optional — leave empty for Ollama Cloud (https://ollama.com),
#                       or set to http://localhost:11434 for a local daemon
LLM_BASE_URL=https://api.deepseek.com/v1

# ── Blender connection ─────────────────────────────────────────
BLENDER_HOST=127.0.0.1
BLENDER_PORT=9876

# ── App ───────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false
